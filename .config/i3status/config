general {
	colors = true
	interval = 15
}

order += "ipv6"
order += "wireless _first_"
order += "ethernet _first_"
order += "volume master"
order += "battery all"
order += "disk /"
order += "cpu_temperature 0"
order += "load"
order += "memory"
order += "tztime local"

wireless _first_ {
	format_up = "W: (%quality at %essid) %ip"
	format_down = "W: down"
}

ethernet _first_ {
	format_up = "E: %ip (%speed)"
	format_down = "E: down"
}

volume master {
	format = "%volume"
	format_muted = "Muted (%volume)"
	device = "default"
	mixer = "Master"
	mixer_idx = 0
}

battery all {
	format = "%status %percentage %remaining"
	last_full_capacity = true
}

disk "/" {
	format = "%avail"
}

cpu_temperature 0 {
	max_threshold = 50
}

load {
	format = "%1min"
}

memory {
	format = "%used~%percentage_used / %available"
	threshold_degraded = "1G"
	format_degraded = "MEMORY < %available"
}

tztime local {
	format = "%Y-%m-%d %H:%M:%S"
}
